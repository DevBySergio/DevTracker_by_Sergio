{
  "name": "DevTrackerBySergio",
  "displayName": "DevTracker by Sergio",
  "description": "Professional analytics dashboard for developers.",
  "version": "1.4.0",
  "publisher": "DevBySergio",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DevBySergio/DevTracker_by_Sergio"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "time tracker",
    "analytics",
    "dashboard",
    "coding stats",
    "charts",
    "local"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devtracker.showStats",
        "title": "DevTracker: Open Dashboard"
      },
      {
        "command": "devtracker.setDailyGoal",
        "title": "DevTracker: Set Daily Goal"
      },
      {
        "command": "devtracker.exportCSV",
        "title": "DevTracker: Export Data (CSV)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1"
  }
}
